[connection]
id=wlan_eap1
uuid=bc2b504b-7aee-4392-bd6e-c95f6372b2b3
type=wifi
autoconnect=false
interface-name=wlan_eap1

[wifi]
hidden=true
mode=infrastructure
ssid=example_ssid

[wifi-security]
key-mgmt=wpa-eap
pmf=1

[802-1x]
anonymous-identity=bob
eap=md5;
identity=alice
password=test_pw
phase1-peaplabel=0
phase2-auth=mschapv2

[match]

[ipv4]
method=disabled

[ipv6]
addr-gen-mode=default
ip6-privacy=1
method=auto

[proxy]
