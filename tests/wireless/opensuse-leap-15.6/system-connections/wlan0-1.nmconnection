[connection]
id=wlan0-1
uuid=ab04c8db-5600-4b0a-a04b-443d8281354a
type=wifi
autoconnect=false
interface-name=wlan0

[wifi]
hidden=true
mode=adhoc
ssid=example_ssid2

[wifi-security]
group=ccmp;
key-mgmt=wpa-psk
pairwise=ccmp;
pmf=2
psk=example_passwd2

[match]

[ipv4]
method=disabled

[ipv6]
addr-gen-mode=default
method=disabled

[proxy]
